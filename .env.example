# Copy this file to .env and fill in values for your environment.
# Lines starting with # are comments and are ignored.

# --- LLM backend ---
LLM_BACKEND=ollama

# --- Ollama (local or RunPod pod) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# OLLAMA_TEMPERATURE=0.2
# OLLAMA_TIMEOUT_S=300

# --- RAG repo ---
# Path to the folder that contains app/rag.py
# Linux / RunPod example:
# RAG_REPO_PATH=/workspace/main-projects
# Windows example:
# RAG_REPO_PATH=C:\Users\Civil\main projects

# --- Kimi (Phase 5) ---
# KIMI_API_KEY=your_key_here
# KIMI_MODEL=kimi-k2

# --- Tuning ---
# AGENT_MAX_ITERATIONS=20
# STEP_MAX_ATTEMPTS=3
# MAX_REPLAN_ATTEMPTS=2
# PYTHON_TOOL_TIMEOUT_S=15

# --- Phase 4: browser + vision ---
VISION_MODEL=qwen2.5vl:7b
SCREENSHOT_DIR=/workspace/AGI/logs/screenshots
BROWSER_HEADLESS=false
# RUNPOD_POD_ID=your_pod_id_here
